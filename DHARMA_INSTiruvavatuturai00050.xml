        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">	
                
                
                    <pb n="1r"/>
                    <ab rend="expanded"><lb n="1r1=1"/>śrī kāci vicuvēcarar tuṇai
                        </ab>
                        <p>
                        <lb n="1r2=2"/>cupama<hi rend="grantha">s</hi>tu co<hi rend="grantha">s</hi>tti śrīmaṉ makāmaṇṭalēcuraṉ Āri
                        <lb n="1r3=3" break="no"/>ya taḷa vipāṭaṉ Āriyar mōkan tavuḷattāṉ Oṭṭiya ta
                        <lb n="1r4=4" break="no"/>ḷa vipāṭaṉ oṭṭiyar mōkan tavuḷattāṉ kaṟṟōm e
                        <lb n="1r5=5" break="no"/>ṉṟuṅ kalai pala yikaḻāṉ peṟṟōm eṉṟum piṟar po
                        <lb n="1r6=6" break="no"/>ruḷ vēḷavāṉ Āṟiloṉṟu kaṭamai koṇṭu Aruḷ
                        <lb n="1r7=7"/>peruka Aṉpu kūrntu Ātular cālaiyum antaṇar vē
                        <lb n="1r8=8" break="no"/>ḷviyum vētavoliyum viḻāvaṟā vītiyuñ caiva ne
                        <lb n="1r9=9" break="no"/>ṟiyun tapōtaṉar maṭaṅkaḷum yiccaiyil muppatti
                        <lb n="1r10=10" break="no"/>raṇṭ' aṟam viḻaṅki Emmaṇṭalamun tiṟaikoṇṭa
                        <lb n="1r11=11"/>ruḷiya rācātirācaṉ rāca-paramēcuvaraṉ rāca-māṟ
                        <lb n="1r12=12" break="no"/>tāṇṭaṉ rāca-kempīraṉ rāca-kula-tilakaṉ rāca-ma
                        <lb n="1r13=13" break="no"/>ṉō-payaṅkaraṉ kaṭal kalaṅkiṉum kāvēri-v-aṟṟiṉumalai
                        <lb n="1r14=14" break="no"/>kuluṅkiṉum maṉaṅkalaṅkāta kaṇṭaṉ pāṣaikku-t tappuva
                        <lb n="1r15=15" break="no"/>rāya kaṇṭaṉ kaṇṭa nāṭu koṇṭu koṇṭa nāṭu ko
                        <lb n="1r16=16" break="no"/>ṭātāṉ poṟumaikku-t tarumaṉ pelattukku vīmaṉ vi
                        <lb n="1r17=17" break="no"/>llukku vicaiyaṉ collukku Ariccantiraṉ Aḻakuk
                        <lb n="1r18=18" break="no"/>ku maṉmataṉ Acupati kecapati narapati taṉapati-y ākiya Āṉai
                        <lb n="1r19=19"/>konti rāyar mallikāṟcuṉa rāyar cīraṅka rāyar piṟa
                        <lb n="1r20=20" break="no"/>vuṭa tēva makārāyar Appiratima maicūr-c cama<hi rend="grantha">s</hi>ttā
                        <lb n="1r21=21" break="no"/>ṉam Āḷita makā cuvāmi ki<hi rend="grantha">ṣ</hi>ṭṭiṉa rāca Uṭaiyarai
                        <lb n="1r22=22"/>yaṉ avarkaḷ Upaya kāvēri mattiyākiya <hi rend="grantha">śrī</hi>raṅka paṭ=ṭa
                        <lb n="1r23=23" break="no"/>ṇattil rattiṉa cimmācaṉārūṭarāyp piṟitivi cām
                        <lb n="1r124=24" break="no"/>pirācciyam ceykiṉṟa ṉāḷaiyil yivarkaḷ kāriyattu
                        <lb n="1r25=25" break="no"/>kku-k karttāvākiya taḷavāy vīra rācaiyaṉ avarkaḷ
                        <lb n="1r26=26"/>ṉāḷaiyil 
                        </p>
                <p>
                            cālivākaṉa cakārttam <num value="1687"> <g type="numeral">1000</g> 6 <g type="numeral">100</g> 8 <g type="numeral">10</g> 7</num> <g type="cross"/>
                        <lb n="1r27=27"/>kaliyukam <num value="4866"> 4 <g type="numeral">1000</g> 8 <g type="numeral">100</g> 6 <g type="numeral">10</g> 1</num>ṟ mēl cellā niṉṟa pār
                        <lb n="1r28=28" break="no"/>ttipa <hi rend="grantha">śrī</hi> mārkaḷi <g type="mācam"/> 3 <g type="cross"/> tītai caṉikkiḷamai Uttir
                        <lb n="1r29=29" break="no"/>āṭa naṭcettiram viratiṉām yōkamum kavulavāka
                        <lb n="1r30=30"/>raṇamum peṟṟa cupatiṉattil 
                </p>
                <p>
                    kōyamputtūr Aṭṭa
                    <lb n="1r31=31" break="no"/>vaṇai kantācāram cuṅkam perammu makamai tēva
                    <lb n="1r32=32" break="no"/><hi rend="grantha">s</hi>ttāṉam mutalākiya cakala Atikāramum ce
                    <lb n="1r33=33" break="no"/>ykiṉṟa rāca <hi rend="grantha">śrī</hi> kuṟikkāra mātaiyaṉ avarkaḷ ṉāḷai
                    <lb n="1r34=34" break="no"/>yil rāca <hi rend="grantha">śrī</hi> caṅkaraiyyaṉ avarkaḷ taṟma pattiṉi
                    <lb n="1r35=35"/>yākiya liṅkammaṉ avarkaḷ kāci <hi rend="grantha">kṣ</hi>ēttirattil
                    <lb n="1r36=36"/>ceyvikkiṟa Aṉṉatāṉa cattirattu-t taṟmattukku-k
                    <lb n="1r37=37"/>ki<hi rend="grantha">ṣ</hi>ṇarācappēṭṭaiyil kūṭiya Eṭṭuvakaip palar
                    <lb n="1r38=38"/>paṭṭakkāṟar ceṭṭikkārarum Eḻutiviccu-k ko
                    <lb n="1r39=39" break="no"/>ṭutta makamai-t taṟma-cācaṉam nericampēṭṭai
                    <lb n="1r40=40"/>kollaṅkōṭu koṭuppēṭṭai pālaikkāṭṭu<surplus>pe</surplus>
                   
                    <pb n="1v"/>
                    
                    <lb n="1v1=41" break="no"/>pēṭṭai pilāppattu vaṇṇārkkāṭu mēlṉāṭu
                    <lb n="1v2=42"/>yinta mārk=kam Uṇi celakkaṇṭimāṟakkam
                    <lb n="1v3=43"/>mēlkāṭṭuppēṭṭai 
                    
                </p>
                <p>       
                    yintap pēṭṭaiyaḷukku
                    <lb n="1v4=44"/>Ēṟu cāttu yiṟaṅku cāttu pākku miḷaku mañcaḷ cala
                    <lb n="1v5=45"/>Arakku nīlam pūvattu pala carakku pukaiyilai cavaḻi
                    <lb n="1v6=46"/>nūl nei cīrakam cantanappoti kōcumpai mu
                    <lb n="1v7=47" break="no"/>talāṉa nica poti 1 k=ku k-keṇṭīrāyaṉ <g type="paṇam"/> <g type="araikkāl"/> nava
                    <lb n="1v8=48"/>tāṉiyam veṟṟilai vellam lavaṇam cēvu Oṉṟu
                    <lb n="1v9=49"/>mutalāṉa kālnāṭai 1 k=ku k-keṇṭīrāyaṉ <g type="paṇam"/> <g type="mākāṇi"/> yin
                    <lb n="1v10=50" break="no"/>tap paṭikki nica poti oṇṇukku kkeṇṭirāya
                    <lb n="1v11=51" break="no"/>ṉ Araikkāl p-paṇamum mūlai-p poti oṇṇukku
                    <lb n="1v12=52"/>mākāṇip paṇamum yinta makamai tīrnta tiraviya
                    <lb n="1v13=53" break="no"/>ttil 
                </p>
                <p>
                        
                        rā <hi rend="grantha">śrī</hi> caṅkaraiyanavarkaḷ tarmapattiniyākiya liṅga
                    <lb n="1v14=54" break="no"/>mmaṉ avarkaḷ kāci <hi rend="grantha">ṣ</hi>cēttiratil ceyta Anna cata
                    <lb n="1v15=55"/>tirattukku tarma Ārccana tirāṟka stātākiya tarmam
                    <lb n="1v16=56"/>cārōttāramāka <choice><orig>ra</orig><reg>na</reg></choice>ṭatti koṇṭu varuvērāka
                    <lb n="1v17=57" break="no"/>vum Eṉṟu Eṭṭu vakai-p palarum Eḻutiviccukko
                    <lb n="1v18=58"/>ṭutta makamaiyum inta tarma-cācaṉa-p-paṭṭaiyam
                </p>
                
                <p>
                    <lb n="1v19=59"/>y-inta-t taṟmattukku yātām oruttar vikā
                    <lb n="1v20=60" break="no"/>tañ ceyta pērkaḷ keṅkai-k karaiyilē
                    <lb n="1v21=61"/>kō-v-atti paṇṇiṉa pāvattai yaṭaivār ā 
                    <lb n="1v22=62" break="no"/>kavum
                </p>
                <p>                    
                    y-inta-t taṟmattai-p paripāla<supplied reason="omitted">ṉa</supplied>ñ ceyta 
                    <lb n="1v23=63"/>pērkaḷ kāci-<hi rend="grantha">ṣe</hi><supplied reason="omitted">ttira</supplied>ttil kō-tāṉam pū-tāṉam A
                    <lb n="1v24=64" break="no"/>ṉṉa-tāṉam coṟṉa-tāṉam cōṭaca-makā-tāna 
                    <lb n="1v25=65" break="no"/>m ceyta puṇṇiyattai y-aṭaiyavār ākavum 
                </p>
                
                <lg n="1" xml:lang="san-Latn" rendition="class:tamil maturity:vernacular"> 
                    <l n="a"><lb n="1v26=66"/>cu-tattā<supplied reason="omitted">t</supplied> ti-kuṇam puṇṇiyam</l>
                    <l n="b">para-tattāṉupāla<lb n="1v27=67" break="no"/>ṉam</l> 
                    <l n="c">para-tattāpakārēṇ<choice><sic>ā</sic><corr>a</corr></choice></l>
                    <l n="d">cu-tattam ni<hi rend="grantha">ṣ</hi>palam
                        <lb n="1v28=68"/>pavēttu <g type="danda">.</g> - <g type="danda">.</g></l> 
                </lg>
                
                <p>
                    y-inta-t taṟma-cācaṉam tirāv<choice><orig>a</orig><reg>i</reg></choice>ṭa
                    <lb n="1v29=69" break="no"/>Aṭcarattil tāmpara-cācaṉattil Eḻuti
                    <lb n="1v30=70" break="no"/>ṉavaṉ tāṉappa-mutaliyār kumāraṉ nīla
                    <lb n="1v31=71" break="no"/>kaṇṭam    
                </p>   
                <p>
                    y-inta Aṭcaram koṭṭiṉavaṉ kō
                    <lb n="1v32=72" break="no"/>ymputtūrul irukkum vicuva kaṟma vaṅki<hi rend="grantha">ṣa</hi>t
                    <lb n="1v33=73" break="no"/>til vīrappa Ācāri makaṉ Ānantā Ācāri <g type="danda"/> <g type="gomutraFinal">§§</g>
                    <lb n="1v34=74"/>Añṉūṟu kuṭi-p pāṭṭattu-p palar paṭṭakkāṟar
                    <lb n="1v35=75"/>Oppitam <g type="danda"/> iruvattu nālu maṉai teluṅka-c
                    <lb n="1v36=76"/>ceṭṭiyaḷ Oppitam <g type="danda"/> paṉireṇṭu nakarattu-p pa
                    <lb n="1v37=77" break="no"/>lar Oppitam <g type="danda"/> vēṭacentūr rāuttamār O
                    <lb n="1v38=78" break="no"/>ppitam <g type="cross"/> kōmuṭṭiyaḷil kuppi ceṭṭi Oppita
                    <lb n="1v39=79" break="no"/>m <g type="danda"/> Allittuṟai vaṟtikar Oppitam <g type="danda"/> tevar
                   <lb n="1v40=80" break="no"/>ku ceṭṭiyaḷ Oppitam <g type="danda"/> caṅkārāka pēṭṭai
                    <lb n="1v41=81"/>varttakar palar Oppitam <g type="gomutraFinal"/> <g type="cross"/> civamayam <g type="cross"/> <g type="gomutraFinal">§§</g> g type="cross"/>
                </p>
                
                
                
                
