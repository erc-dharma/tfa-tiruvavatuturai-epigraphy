        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:vernacular">	
                
                <p>
                    <pb n="1r"/>
                    <title rend="plain"><lb n="1r1=1"/>śrī kāci vicuvēcarar tuṇai
                        <title/>
                        
                        <lb n="1r2=2"/>cupama<hi rend="grantha">s</hi>tu co<hi rend="grantha">s</hi>tti śrīmaṉ makāmaṇṭalēcuraṉ Āri
                        <lb n="1r3=3" break="no"/>ya taḷa vipāṭaṉ Āriyar mōkan tavuḷattāṉ Oṭṭiya ta
                        <lb n="1r4=4" break="no"/>ḷa vipāṭaṉ oṭṭiyar mōkan tavuḷattāṉ kaṟṟōm e
                        <lb n="1r5=5" break="no"/>ṉṟuṅ kalai pala yikaḻāṉ peṟṟōm eṉṟum piṟar po
                        <lb n="1r6=6" break="no"/>ruḷ vēḷavāṉ Āṟiloṉṟu kaṭamai koṇṭu Aruḷ
                        <lb n="1r7=7"/>peruka Aṉpu kūrntu Ātular cālaiyum antaṇar vē
                        <lb n="1r8=8" break="no"/>ḷviyum vētavoliyum viḻāvaṟā vītiyuñ caiva ne
                        <lb n="1r9=9" break="no"/>ṟiyun tapōtaṉar maṭaṅkaḷum yiccaiyil muppatti
                        <lb n="1r10=10" break="no"/>raṇṭ' aṟam viḻaṅki Emmaṇṭalamun tiṟaikoṇṭa
                        <lb n="1r11=11"/>ruḷiya rācātirācaṉ rācaparamēcuvaraṉ rācamāt
                        <lb n="1r12=12"/>tāṇṭaṉ rācacempīraṉ rācakula tilakaṉ rāca
                        <lb n="1r13=13"/>ṉō payaṅkaraṉ kaṭal kalaṅkiṉum kāvēri vaṟṟiṉumalai
                        <lb n="1r14=14"/>kuluṅkiṉum maṉaṅkalaṅkāta kaṇṭaṉ pāṣaikkut tappuva
                        <lb n="1r15=15"/>rāya kaṇṭaṉ kaṇṭa nāṭu koṇṭu koṇṭanāṭu ko
                        <lb n="1r16=16"/>ṭātāṉ poṟumaikkut tarumaṉ pelattukku vīmaṉ vi
                        <lb n="1r17=17"/>llukku vicaiyaṉ collukku ariccantiraṉ aḻakuk
                        <lb n="1r18=18"/>ku maṉmataṉ acupati kecapati narapati taṉapatiyākiya āṉai
                        <lb n="1r19=19"/>kontirāyar mallikāṟcuṉarāyar cīraṅka rāyar piṟa
                        <lb n="1r20=20"/>vuṭa tēva makārāyar appiratima maicūrc camastā
                        <lb n="1r21=21"/>ṉam āḷita makā cuvāmi kiṣṭṭaṉa rāca uṭaiyarai
                        <lb n="1r22=22"/>yaṉavarkaḷ upaya kāvēri mattiyākiya śrīraṅka paṭṭa
                        <lb n="1r23=23"/>ṇattil rattiṉa cimmācaṉārūṭarāyp piṟitivi cām
                        <lb n="1r124=24"/>pirācciyam ceykiṉṟa ṉāḷaiyil yivarkaḷ kāriyattu
                        <lb n="1r25=25"/>kkuk karttāvākiya taḷavāy vīra rācaiyaṉavarkaḷ
                        <lb n="1r26=26"/>ṉāḷaiyil cālivākaṉa cakārttam 1687
                        <lb n="1r27=27"/>kaliyukam 4866n mēl cellāniṉṟa pār
                        <lb n="1r28=28"/>ttipa śrī mārkaḷi mī 3m tēti caṉikkiḻamai uttira
                        <lb n="1r29=29"/>āṭa naṭcettiram viratiṉām yōkamum kavulavāka
                        <lb n="1r30=30"/>raṇamum peṟṟa cupatiṉattil kōyamputtūr aṭṭa
                        <lb n="1r31=31"/>vaṇai kantācāram cuṅkam perammu makamai tēva
                        <lb n="1r32=32"/>sttāṉam mutalākiya cakala atikāramum ce
                        <lb n="1r33=33"/>ykiṉṟa rācaśrī kuṟikkāra mātaiyaṉavarkaḷ ṉāḷai
                        <lb n="1r34=34"/>yil rācaśrī caṅkaraiyyaṉavarkaḷ taṟma pattiṉi
                        <lb n="1r35=35"/>yākiya liṅkammaṉavarkaḷ kāci kṣēttirattil
                        <lb n="1r36=36"/>ceyvikkiṟa aṉṉatāṉa cattirattut taṟmattukkuk
                        <lb n="1r37=37"/>kiruṣṇaracap pēṭṭaiyil kūṭiya eṭṭuvakaip palar
                        <lb n="1r38=38"/>paṭṭakkārar ceṭṭikkārarum eḻutiviccuk ko
                        <lb n="1r39=39"/>ṭutta makamait taṟma cācaṉam nericampēṭṭai
                        <lb n="1r40=40"/>kollaṅkōṭu koṭuppēṭṭai pālaikkāṭ[p]
                </p>
                <p>
                    
                    <pb n="1v"/>
                    
                    <lb n="1v1=41"/>pēṭṭai pilāppattu vaṇṇārkkāṭu mēnnāṭu
                    <lb n="1v2=42"/>yinta mārkkam uṇṇi celak kaṇṭi māṟakkam
                    <lb n="1v3=43"/>mēl kāṭṭup pēṭṭai yintap pēṭṭaiyaḷukku
                    <lb n="1v4=44"/>ēṟu cāttu yiṟaṅku cāttu pākku miḷaku mañcaḷ cala
                    <lb n="1v5=45"/>arakku nīlam pūvattu pala carakku pukaiyilai cavaḷi
                    <lb n="1v6=46"/>nūl nei cīrakam cantanappoti kōcumpai mu
                    <lb n="1v7=47"/>talāṉa nica poti 1kkuk keṇṭarāyaṉ paṇam araikkāl nava
                    <lb n="1v8=48"/>tāṉiyam veṟṟilai vellam lavaṇam cēvu oṉṟu
                    <lb n="1v9=49"/>mutalāṉa kālnāṭai 1kkuk keṇṭarāyaṉ paṇam mākāṇi yin
                    <lb n="1v10=50"/>tap paṭikki nica poti oṇṇukkuk keṇṭi rāya
                    <lb n="1v11=51"/>ṉ araikkāl paṇamum mūlaip poti oṇṇukku
                    <lb n="1v12=52"/>mākāṇip paṇamum yinta makamai tīrnta tiraviya
                    <lb n="1v13=53"/>tatil rācacrī caṅkaraiyanavarkaḷ tarmapattiniyākiya liṅga
                    <lb n="1v14=54"/>mamāṉavarkaḷ kāciś cēttiratil ceyta anna cata
                    <lb n="1v15=55"/>tirattukku tarma āccantirākai stātākiya tarmam
                    <lb n="1v16=56"/>cārōttāramāka naṭatti koṇṭu varuvōrāka
                    <lb n="1v17=57"/>vum eṉṟu eṭṭu vakaip palarum eḻutiviccukko
                    <lb n="1v18=58"/>ṭutta makamaiyum inta tarma <lb n="1v18=58"/>[...] cācaṉa-p-paṭṭaiyam
                </p>
                
                <p>
                    <lb n="1v19=59"/>y-inta-t taṟmattukku yātām oruttar vikā
                    <lb n="1v20=60" break="no"/>tañ ceyta pērkaḷ keṅkai-k karaiyilē
                    <lb n="1v21=61"/>kō-v-atti paṇṇiṉa pāvattai yaṭaivār ā 
                    <lb n="1v22=62" break="no"/>kavum
                </p>
                <p>                    
                    y-inta-t taṟmattai-p paripāla<supplied reason="omitted">ṉa</supplied>ñ ceyta 
                    <lb n="1v23=63"/>pērkaḷ kāci-<hi rend="grantha">ṣe</hi><supplied reason="omitted">ttira</supplied>ttil kō-tāṉam pū-tāṉam A
                    <lb n="1v24=64" break="no"/>ṉṉa-tāṉam coṟṉa-tāṉam cōṭaca-makā-tāna 
                    <lb n="1v25=65" break="no"/>m ceyta puṇṇiyattai y-aṭaiyavār ākavum 
                </p>
                
                <lg n="1" xml:lang="san-Latn" rendition="class:tamil maturity:vernacular"> 
                    <l n="a"><lb n="1v26=66"/>cu-tattā<supplied reason="omitted">t</supplied> ti-kuṇam puṇṇiyam</l>
                    <l n="b">para-tattāṉupāla<lb n="1v27=67" break="no"/>ṉam</l> 
                    <l n="c">para-tattāpakārēṇ<choice><sic>ā</sic><corr>a</corr></choice></l>
                    <l n="d">cu-tattam ni<hi rend="grantha">ṣ</hi>palam
                        <lb n="1v28=68"/>pavēttu <g type="danda">.</g><g type="dash">.</g><g type="danda">.</g></l> 
                </lg>
                
                <p>
                    y-inta-t taṟma-cācaṉam tirāv<choice><orig>a</orig><reg>i</reg></choice>ṭa
                    <lb n="1v29=69" break="no"/>-Aṭcarattil tāmpara-cācaṉattil Eḻuti
                    <lb n="1v30=70" break="no"/>ṉavaṉ tāṉappa-mutaliyār kumāraṉ nīla
                    <lb n="1v31=71" break="no"/>kaṇṭam    
                </p>   
                <p>
                    y-inta Aṭcaram koṭṭiṉavaṉ kō
                    <lb n="1v32=72"/>yampu tturulirukkum vicuva karma vaṅkiśat
                    <lb n="1v33=73"/>til vīrappa ācāri makaṉ ānantā ācāri u
                    <lb n="1v34=74"/>aññūṟu kuṭip pāṭṭattuppalar paṭṭakkārar
                    <lb n="1v35=75"/>oppitam iruvattu nālu maṉai teluṅkac
                    <lb n="1v36=76"/>ceṭṭiyaḷ oppitam paṉṉiraṇṭu nakarattuppa
                    <lb n="1v37=77"/>lar oppitam vētacentūr rāuttamār o
                    <lb n="1v38=78"/>ppitam kōmuṭṭiyaḷil kuppi ceṭṭi oppita
                    <lb n="1v39=79"/>m allittuṟai oppitam caṅkārāka pēṭṭai
                    <lb n="1v40=80"/>varttakarkaḷ palar oppitam 2 civamayam.
                </p>
                
                
                
                
            </div>
            
