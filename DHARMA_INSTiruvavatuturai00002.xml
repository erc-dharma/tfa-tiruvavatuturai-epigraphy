        <body>
            
            
            <div type="edition" xml:lang="tam-Latn" n="1" rendition="class:tamil maturity:83215">		
                
                
                <pb n="1r"/>
                <p>
                    <lb n="1r1=1"/> civamayam
                </p>
                <p>
                    <lb n="1r2=2"/><hi rend="grantha"><supplied reason="omitted">sva</supplied>sti śrī</hi> cālivākaṉa cakā<hi rend="grantha">ptam</hi> <num value="1674"> <g type="numeral">1000</g> 6 <g type="numeral">100</g> 7 <g type="numeral">10</g> 4 </num><seg type="aksara">kku</seg> mē<supplied reason="omitted">l</supplied> ce<supplied reason="omitted">l</supplied>lā niṉṟa Āṅki 
                    <lb n="1r3=3" break="no"/><supplied reason="omitted">ra</supplied><hi rend="grantha">sa</hi><g type="varuṣam"/> mārkaḷi mārkaḷi <g type="mācam"/> <num value="22">2 <g type="numeral">10</g> 2</num> Uttarāyaṇattu-p pūruva paṭcamuñ cōmavā 
                    <lb n="1r4=4" break="no"/>ramum Acupati naṭcettiramuṅ kūṭiṉa cupa-tiṉattilē 
                    
                </p>
                <p>
                    tiruvāvaṭutu 
                    <lb n="1r5=5" break="no"/>ṟaip paṇṭāra caṉṉiti Avarkaḷ Ampalavāṇa cuvāmi pūcai 
                    <lb n="1r6=6"/>ma<hi rend="grantha">hēsva</hi>ra pūcaikki-t 
                </p>
                <p>
                    tēvai nakarātipaṉ - cētu mūlaraṭ 
                    <lb n="1r7=7" break="no"/>cā turantaraṉ - Irāmanāta cuvāmi paruvatavaṟtani ammai kāri
                    <lb n="1r8=8" break="no"/>ya turantaraṉ - cuppiramaṇiya pātāravinta cēvi<choice><orig>ta</orig><reg>ka</reg></choice>ṉ - parar=āca ciṅka
                    <lb n="1r9=9" break="no"/>m - <choice><orig>va</orig><reg>pa</reg></choice>ra-r=āca-cūriyaṉ para-r=āca-cēkaraṉ Iravi-kula cēkaraṉ corimut 
                    <lb n="1r10=10" break="no"/>tu vaṉṉiyaṉ tuṭṭa rā<choice><orig>sa</orig><reg>ca</reg></choice>r kaṇṭaṉ cāṭikkāṟar kaṇṭaṉ cā 
                    <lb n="1r11=11" break="no"/>mi-t-turōkikaḷ muṇṭaṉ Antampara kaṇṭaṉ Aṭiyār vēḷai 
                    <lb n="1r12=12" break="no"/>k=kāraṉ Araca-rāvaṇa-rāmaṉ pañcattu vara-māri <choice><orig>ya</orig><reg>pa</reg></choice>ṉukkuvarāta <!-- check, the formula seems jumbled up here ;in earlier grants it is pañcattu māri paṉukkuvār kaṇṭaṉ -->ka 
                    <lb n="1r13=13" break="no"/>ṇṭaṉ paṭṭamāṉaṅ kā<add place="below">ttā</add>ṉ paṭ=ṭam parampaṭattāṉ tālikku vēli 
                    <lb n="1r14=14"/>AIvāy-p puli Iḷañ-ciṅkan taḷañ-ciṅkam - <!-- these hyphens are in the grant --> vīraveṇpā mālai
                    <lb n="1r15=15"/>vaikai vaḷanāṭaṉ - parataḷa vipāṭaṉ - pañcavaṟṉa r=āya r=āvut=taṉ puva 
                    <lb n="1r16=16" break="no"/>ṉēka vīraṉ vētiyar kāvalaṉ koṭ=ṭamaṭakki vaiyyāḷi nār=āyaṇa 
                    <lb n="1r17=17" break="no"/>ṉ Ivuḻi pāvaṭi mitittēṟuvār kaṇṭaṉ pakai-maṉṉar ciṅkam 
                    <lb n="1r18=18"/>Āṟ<choice><orig>t</orig><reg>ṟ</reg></choice>iṟ pācci kaṭaliṟ pācci - catturukkaḷ miṇṭaṉ mēvalar 
                    <lb n="1r19=19"/>kōḷari - vīra-kempīraṉ kīṟti-p piṟatā<add place="below">pa</add>ṉ kapaṭa-nāṭaka-cūttira-p-piṟa
                    <lb n="1r20=20" break="no"/>tāpaṉ patti-muttip-piṟiyaṉ A<hi rend="grantha">ṣṭa</hi>-leṭcumi-vācaṉ caṟpa<unclear>ṉ</unclear> 
                    <lb n="1r21=21" break="no"/>ṉa-pā<hi rend="grantha">ṣā</hi> vīṭcaṇaṉ cakala-kuṇa-campaṉṉaṉ caṅkīta-ca 
                    <lb n="1r22=22" break="no"/>āyittiya-vittiyā-viṉōtaṉ vīṇā-p-piṟacaṅkaṉ vīrai 
                    <lb n="1r23=23" break="no"/>vaḷanāṭaṉ toṇṭiyan tuṟai kāvalaṉ Aṭaikka 
                    <lb n="1r24=24" break="no"/>laṅ kāttāṉ - vaṉṉiyarāṭ=ṭan taviḻttāṉ - mūvarā 
                    <lb n="1r25=25" break="no"/>ya kaṇṭaṉ cāmitturōki veṇṭaya kāvala 
                    <lb n="1r26=26" break="no"/>ṉ - vīrataṇṭai cēmattalai viḷaṅkiya tāḷiṉāṉ tu 
                    <lb n="1r27=27" break="no"/>rai rāyaṉ ceyatuṅka rāyaṉ vami<hi rend="grantha">ṣā</hi>tipaṉāṉa tukavūr 
                    <lb n="1r28=28"/>k-kūṟṟat=tu-k kāttūrāṉa kulōttuṅka cōḷa nallū 
                    <lb n="1r29=29" break="no"/>r k=kīḻpāl viraiyāta kaṇṭaṉilirukkum <hi rend="grantha">śrī</hi>matu 
                    <lb n="1r30=30"/>Iraṇiyakeṟpa-vāci ravi-kula rekunāta-c cētupati kā 
                    <lb n="1r31=31" break="no"/>ttatēvaravarkaḷ vaṅkucōtta-<add place="below">ka</add>rāṉa <hi rend="grantha">śrī</hi>matu cellamuttu 
                   e <lb n="1r32=32"/>vicaiya rekunāta cētupati kāttatēvaravarkaḷ - </p> 
                <p>ṅkaḷ
                
                
                
                <pb n="1v"/>
                    <lb n="1v1=33"/>mātā-pitāviṉuṭaiya vaṟkkattukkum puṇṇiyamāka-t taruma-cā
                    <lb n="1v2=34" break="no"/>taṉa-p-paṭṭayaṅ koṭuttapaṭi muṉ Eṅkaḷ turaittaṉa paramparai
                    <lb n="1v3=35" break="no"/>yil - cālivākaṉa ca<hi rend="grantha">hāpt</hi>am <num value="1582"> <g type="numeral">1000</g> 5 <g type="numeral">100</g> 8 <g type="numeral">10</g> 2 </num><seg type="aksara">k=ku</seg> mēṟ cellā
                    <lb n="1v4=36"/>niṉṟa cāṟuvari <g type="varuṣam"/> māka māca puṇṇiya-kālat=tilē tiruvāvaṭu
                    <lb n="1v5=37" break="no"/>tuṟai Ātīṉam Ampalavāṇa paṇṭāra caṉṉati Avarkaḷuk=ku -
                    <lb n="1v6=38"/><hi rend="grantha">śrī</hi>matu tirumalai-c cētupati rekunāta-t tēvaravarkaḷ taruma-cā<supplied reason="omitted">ca</supplied>
                    <lb n="1v7=39" break="no"/>ṉa-p-paṭi kaṅkaṇi kaṭṭi ceriṉāñcivayal <add place="below">nā</add>ṇāk=kuṭi Inta nāṉkil
                    <lb n="1v8=40"/>kaṅkaṇi kaṭ=ṭi ceriṉāñcivayal inta mūṉṟun tāṅkaḷ aṉupavit
                    <lb n="1v9=41" break="no"/>tu varukiṟatuṉālē taṅkaḷ nāṇākkuṭikku-p patilāy Eḻu-kō
                    <lb n="1v10=42" break="no"/>ṭṭai nāṭṭil Orur vaṭṭakaiyil nāṭṭucēriyai taṅkaḷu
                    <lb n="1v11=43" break="no"/>kku-k kaṭ=ṭaḷaiyiṭṭōm 
                </p>
                <p>
                    nāṭṭucēri Ellai-y āvatu 
                    <list><item>kiḻakku Ā
                            <lb n="1v12=44" break="no"/>yāṅ kōṭṭai-k kaṇvāy nīrppiṭikku mēṟku -</item> 
                        <item>t-teṟku
                            <lb n="1v13=45"/>taṉiccak=kaṇavāy vaṭakālukkum neṭṭēntaṟ kuḷakkālu
                            <lb n="1v14=46" break="no"/>kkum vaṭak=ku </item>
                        <item> mēṟku Ataṅkuṭi-k kīḻpuṟattellaikku-k kiḻak
                            <lb n="1v15=47" break="no"/>ku -</item>
                        <item>vaṭak=ku - tiruppoṟkōṭṭai nañcaimāluk=ku-t teṟku</item>
                    </list>
                    
                </p>
                <p>
                    <lb n="1v16=48"/>Inta nāṉkellaikku<choice><orig>ṉ</orig><reg>ḷ</reg></choice> p-paṭ=ṭa tiṭṭut tiṭal māvaṭai <surplus>māvaṭai</surplus> māva
                    <lb n="1v17=49"/>ṭai mēl ṉōkkiya maram kīḻ ṉōkkiya kiṇaṟum Āttu-k-kā
                    <lb n="1v18=50" break="no"/>l Ūḷattu-k-kāl c-cila taru pā<hi rend="grantha">ṣā</hi>ṇa niti niṭcēpamum a<hi rend="grantha">ṣṭa</hi>
                    <lb n="1v19=51"/>pōka tēca cuvāmiyaṅkaḷum viniyāti vikkiraiyaṅka
                    <lb n="1v20=52" break="no"/>ḷukku yōkkiyamāka 
                </p>
                <p>
                    cantirātitt<choice><orig>r</orig><reg>v</reg></choice>ā=r Uḷḷavaraikkum
                    <lb n="1v21=53"/>Ātīṉa paramparaiyāka tāṅkaḷē Āṇṭaṉupavittu k-ko
                    <lb n="1v22=54" break="no"/>ḷḷa-k kaṭavārkaḷākavum
                </p>
                 <p xml:lang="tel-Latn" rend="large"><lb n="1v23=55"/>śrī subramaṇiya 
                <lb n="1v24=56"/>pādāra vindam tuṇai <!-- this seems written by someonw who was copying the signature without really knowing telugu aplphabet, the shape of the letters is rather strange -->
                </p>
                <p>
                    <lb n="1v25=57"/>intat tarumattai-p paripālaṉam paṇṇiṉavarkaḷ keṅkai
                    <lb n="1v26=58"/>k-karaiyiluñ cētukkaraiyilu puṇṇiya <hi rend="grantha">sta</hi>laṅkaḷilē A
                    <lb n="1v27=59" break="no"/>ṉēka civaliṅka-p piṟatiṭṭai maṭa-p-piṟatiṭṭai Akkir=ā=r=ap piṟatiṭ
                    <lb n="1v28=59" break="no"/>ṭai kaṉṉikā tāṉam paṇṇiṉa palaṉai Aṭaivārkaḷ inta-t
                    <lb n="1v29=60"/>tarumattukku yātorut=tar A<hi rend="grantha">hi</hi>tañ ceyta pērkaḷ keṅkai
                    <lb n="1v30=61"/>k=karaiyiluñ cētukkaraiyiluṅ kārāmpacuvaiyum pi
                    <lb n="1v31=62" break="no"/>rāmaṇaraiyuṅ kuruvaiyu mātā pitāvaiyuṅ koṉṟa
                    <lb n="1v32=63"/>tōṣat=tilēyum Aṉēka civatalaṅkaḷilē civatturōka
                    <lb n="1v33=64" break="no"/>m paṇṇiṉa narakattilēyum pō<add place="below">ka</add>k kaṭavararākavum
                </p>
               
                <p>
                    ippaṭikku
                    <lb n="1v34=65"/><hi rend="grantha">śrī</hi> cellamuttu vicaiya rekuṉātac cētupati kātta tēvaravar
                    <lb n="1v35=66" break="no"/>kaḷ tiruvāvaṭutuṟai-p paṇṭāra-c caṉṉati Avarkaḷ Ampalavā
                    <lb n="1v36=67" break="no"/>ṇa cuvāmi pūcai ma<hi rend="grantha">hē</hi>cuvara pūcaikku-t tāmpira-cātaṉaṅ
                    koṭut
                   <lb n="1v37=68" break="no"/>tōm <g type="gomutraFinal">.</g>
                    
                </p>  
                    
                
