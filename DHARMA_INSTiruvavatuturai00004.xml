        <body>            
            
            <div type="edition" xml:lang="tam-Latn" n="1" rendition="class:tamil maturity:83215">		
                
                <pb n="1r"/>
                
                <ab>
                    <lb n="1r1=1"/><g ref="sym:tam-pillaiyarCuli" type="ideogram">@</g> muttu-c-cilāpa-p-paṭ=ṭayam <g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g> civa-yōka-ṉāyaki tuṇai <g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g>
                </ab>
                
                <ab>	
                    <lb n="1r2=2"/><hi rend="grantha">svasti śrī
                    </hi>
                </ab>
                
                <p>  
                    <hi rend="grantha">śā</hi><choice><orig>vī</orig><reg>li</reg></choice>vā<hi rend="grantha">ha</hi>na-<hi rend="grantha">śakābdaṁ</hi> <num value="1461"><g type="numeral">1000</g> 4 <g type="numeral">100</g> 6 <g type="numeral">10</g> 1</num>  
                    <lb n="1r3=3"/>Āṇṭu viḷampi-ṉāma-<hi rend="grantha">saṃ</hi>va<hi rend="grantha">scara</hi>ttil Ut=ta<hi rend="grantha">rā</hi>
                    <lb n="1r4=4" break="no"/>yaṇattil <hi rend="grantha">śaśira-ṛtu</hi>vil <hi rend="grantha">māgha-māsaṃ</hi> <num value="14"><g type="numeral">10</g> <g type="numeral">4</g></num> <g ref="sym:tam-teti" type="ideogram">@</g>  
                    <lb n="1r5=5"/><hi rend="grantha">kṛṣṇa-pakṣa</hi>t=til <hi rend="grantha">śukra</hi>-vā<hi rend="grantha">ramuṃ</hi> <hi rend="grantha">tra</hi>yō<hi rend="grantha">daśi</hi>yu=M <hi rend="grantha">śa</hi>
                    <lb n="1r6=6" break="no"/><hi rend="grantha">ṣṭa</hi>-naṭcat=tiramum <hi rend="grantha">yu</hi>va-nā<hi rend="grantha">ma</hi>-yō<hi rend="grantha">gamuṃ</hi> <seg rend="check">nā<unclear reason="eccentric_ductus">na</unclear>var<!--nākava?--></seg>-<hi rend="grantha">kara</hi>ṇa 
                    <lb n="1r7=7" break="no"/><hi rend="grantha">muṃ</hi> pe<choice><orig>t=t</orig><reg>ṟ=ṟ</reg></choice>a makā<hi rend="grantha">śi</hi>va<hi rend="grantha">rātri-pu</hi>ṇya-<hi rend="grantha">kāla</hi>t=til
                </p>
                
                <p>
                    pāṇṭi ma
                    <lb n="1r8=8" break="no"/>ṇṭalam teṭciṇa <hi rend="grantha">simmāsa</hi>nā<hi rend="grantha">dhipa</hi>tiyāṉ <hi rend="grantha">śrī</hi>
                    <lb n="1r9=9"/><hi rend="grantha">matu</hi> yēlinavā<hi rend="grantha">ru</hi> <hi rend="grantha">svāmi</hi>-y-avarkaḷ ceṅkōlē ra
                    <lb n="1r10=10" break="no"/>ṭcikki teṭciṇa pūmikki teṟkku veḷḷāt=tuk
                    <lb n="1r11=11" break="no"/>ku mēṟkku karu<hi rend="grantha">ṃgu</hi>ḷam celam kā<hi rend="grantha">ṃge</hi>yamāṉa ma
                    <lb n="1r12=12" break="no"/>laikki kiḻakku Oḻukumalai malaiṅkaṉar karuṅ ku
                    <lb n="1r13=13" break="no"/>ḷam kaṉṉi varaikkum kiḻakku pāṇṭi maṇ
                    <lb n="1r14=14" break="no"/>ṭalam Aṉpattāṟu kartta<supplied reason="omitted">t</supplied>tuk=ku māvili vā
                    <lb n="1r15=15" break="no"/>ṇa-makār<choice><orig>a</orig><reg>ā</reg></choice>ca pāṇṭiya rāma rāma Atirācarāy
                    <lb n="1r16=16" break="no"/>ār Ēlunavār kaṟttākkaḷ avarkaḷ narapatipe
                    <lb n="1r17=17" break="no"/>ppai Eḻu<hi rend="grantha">pa</hi>ttireṇṭu pāḷaiyat ta<choice><sic>laṉa</sic><corr>lai</corr></choice>vamāru
                    <lb n="1r18=18" break="no"/>kkum Oru-k-kuṭai-k-kī<choice><orig>ḷ</orig><reg>ḻ</reg></choice> ceṅkōl aracu cel<choice><orig>u</orig><reg>i</reg></choice>t
                    <lb n="1r19=19" break="no"/>ti Aruḷu<supplied reason="subaudible">m</supplied> maturai Ātikkam uṭaiya makā-maṇṭa⌈
                    <lb n="1r20=20" break="no"/>lēcuvaramāṉ pācaikkum tappu varāta kaṇta
                    <lb n="1r21=21" break="no"/>ṉ muvarāya kaṇṭaṉ kaṇṭaṉāṭu koṇṭu koṇ
                    <lb n="1r22=22" break="no"/>ṭa ṉāṭu kuṭātāṉ pāṇṭi-maṇṭalam paramēcuvaraṉ
                    <lb n="1r23=23"/>cō<choice><orig>ḷa</orig><reg>ḻa</reg></choice>maṇṭalam y-irupattiṉāṟ-k kātam uṭaiya
                    <lb n="1r24=24"/>maṉṉarai maṭakki Oṭikki navacaiyāl nāṭca
                    <lb n="1r25=25" break="no"/>ya-kōṭṭam aṭakki Aracu kuṭuttu tērai=k= koḷḷu
                    <lb n="1r26=26" break="no"/>m pa<hi rend="grantha">dma</hi>-nā<hi rend="grantha">bha</hi> muttu-cilāpam uṭaiya perumāṉ pē 
                    <lb n="1r27=27" break="no"/>r atiya mā-malai para-rāca-rāca-muṉi maturai turait-
                    <lb n="1r28=28" break="no"/>taṉam A<hi rend="grantha">ṣṭa</hi>-campaṉṉa-rācātirāyar tiṅkaḷ-c cut
                    <lb n="1r29=29" break="no"/>ta vaṅki<hi rend="grantha">ṣa</hi> piṟama-teṭcaṇā karaikki ceṅkōl uṭa
                    <lb n="1r30=30" break="no"/>ṉ c-cel<choice><orig>i</orig><reg>u</reg></choice>tti y-aruḷum cuvāmiyār avarkaḷ-āṉa 
                </p>
                <p>
                    <lb n="1r31=31"/><hi rend="grantha">śrī</hi> vicaiya kumāra muttureṅka cokkaliṅ
                    <lb n="1r32=32" break="no"/>ka tirumalai ṉāyakkar cuvāmiyār avarkaḷ tiruk
                    <lb n="1r33=33" break="no"/>karuṇai purintu
                </p>
                
                <p>
                    <hi rend="grantha">svē</hi>ta-natī-<hi rend="grantha">dakṣi</hi>ṇa-tīram ākiya p
                    <lb n="1r34=34" break="no"/>āṇṭi-ṉāṭṭi<choice><sic>s</sic><corr>l</corr></choice> miḻalai-k-kū<choice><orig>tt</orig><reg>ṟṟ</reg></choice>attil 
                    
                    <pb n="1v"/>
                    <lb n="1v1=35"/>naṭuvil kū<choice><orig>tt</orig><reg>ṟṟ</reg></choice>am taṉiyūr <hi rend="grantha">brahmadeśaṃ</hi> <hi rend="grantha">pa</hi>vi<hi rend="grantha">tra</hi>-māṇikka-
                    <lb n="1v2=36" break="no"/>m caturuvē<hi rend="grantha">da</hi>-maṅkalapu<hi rend="grantha">ra</hi>m <hi rend="grantha">Āti-kailāsa-śi</hi>vapu<hi rend="grantha">ra</hi>
                    <lb n="1v3=37"/>u<hi rend="grantha">kṣētra</hi>m ākiya tirupperuntuṟaiyil viḷaṅkā
                    <lb n="1v4=38"/>ṉiṉṟa <hi rend="grantha">brahma</hi>-vi<hi rend="grantha">ṣṇu-rudra-mahe</hi>cuva<hi rend="grantha">ra</hi>-catāciva-<hi rend="grantha">bindu</hi>nā<hi rend="grantha"><choice><orig>d</orig><reg>th</reg></choice></hi>a-pa<hi rend="grantha">r</hi>
                    <lb n="1v5=39" break="no"/><hi rend="grantha">āśakti</hi>kku mēl ākiya pa<hi rend="grantha">rā</hi>pa<hi rend="grantha">ra</hi>-ni<hi rend="grantha">rāma</hi>ya-nirkkuṇa-ni<hi rend="grantha">rā</hi>la
                    <lb n="1v6=40" break="no"/>mpa-ni<hi rend="grantha">ra</hi>ti<hi rend="grantha">sa</hi>ya-<hi rend="grantha">Akha</hi>ṇṭākā<hi rend="grantha">ra</hi>-<hi rend="grantha">saccidā</hi>na<hi rend="grantha">nda</hi>-corūpa-co<unclear reason="eccentric_ductus">ya</unclear><supplied reason="lost">m</supplied>
                    <lb n="1v7=41"/>piṟa<hi rend="grantha">kāsa</hi>-va<hi rend="grantha">stu</hi>-v-ākiya <hi rend="grantha">śrī-Ātma</hi>nā<hi rend="grantha">tha</hi>-cuvāmiyar canni
                    <lb n="1v8=42" break="no"/>tāṉattukku
                </p>
                
                <p> 
                    ṉām nintam āka tāṉam paṇṇik kuṭuttatu ma
                    <lb n="1v9=43" break="no"/>ṉṉār muttu-c-cilāpattil Oru tōṇiyum Añcu kallum
                    <lb n="1v10=44"/>tūttukkuṭi muttu-c-cilāpattil Oru tōṇiyum Añcu kal
                    <lb n="1v11=45" break="no"/>lum caṟuva-māṉṉiyam āka māci <g ref="sym:tam-matam" type="ideogram"/><hi rend="grantha">m catu<reg>r</reg>ddaśi</hi>yil makā-<hi rend="grantha">śi</hi>
                    <lb n="1v12=46" break="no"/>va-<hi rend="grantha">rātri-puṇya-kāla</hi>ttil <hi rend="grantha">miṉāṭci-sundarēśvara-svāmi-sa</hi>n=ni<hi rend="grantha">dhi</hi>
                    <lb n="1v13=47" break="no"/>yil <hi rend="grantha">svarṇapuṣkari</hi>ṇi tīṟtakkaraiyil <hi rend="grantha">dā</hi>na-<hi rend="grantha">pūrvva</hi>māka tāmpira
                    <lb n="1v14=48"/>cātana-p-paṭṭayam paṇṇi-k-kuṭutta paṭiyiṉālē 
                </p>
                
                <p>	
                    Ātitta-cantirar<supplied reason="omitted">ka</supplied>
                    <lb n="1v15=49" break="no"/>ḷ uḷḷa varaikkum Āṇṭu Aṉupavittuk koḷvārkaḷ ākavu
                    <lb n="1v16=50" break="no"/>m
                </p>	
                <p>
                    Inta-p paṭṭaya-p paṭikki paripālaṉam paṇṇi <hi rend="grantha">ko</hi>ṇṭa
                    <lb n="1v17=51" break="no"/>varkaḷ kāciyil keṇkaik karaiyilē kōṭi civa
                    <lb n="1v18=52" break="no"/>liṅka-pirati<hi rend="grantha">ṣṭai</hi>yum kōṭi vi<hi rend="grantha">ṣṇu</hi>-pirati<hi rend="grantha">ṣṭai</hi>yum kōṭi
                    <lb n="1v19=53" break="no"/>piṟama-pirati<hi rend="grantha">ṣṭai</hi>yum ceyta puṇṇiya-p pala<unclear>ṅka</unclear>ḷai peruva
                    <lb n="1v20=54" break="no"/>rkaḷ
                    Itaṟkku yātorutar Akitam paṇṇiṉavarkaḷ ke
                    <lb n="1v21=55" break="no"/>ṅkaik karaiyilē kārāmpacuvai koṉṟa tō<hi rend="grantha">ṣa</hi>ttilu
                    <lb n="1v22=56" break="no"/>m piṟama-kattiyum <hi rend="grantha">śrī</hi>-kattiyum cicu-kattiyum māturu-tu
                    <lb n="1v23=57" break="no"/><hi rend="grantha">ṟo</hi>kamum paṇṇiṉa tōṣattil pōkak kaṭavār ākavum
                </p>
                
                <p>
                    ⌈
                    <lb n="1v24=58" break="no"/>cokkaliṅkam mīṉāṭci reṅkanāyakar Uccimalaippiḷḷaiya
                    <lb n="1v25=59" break="no"/> r māriyammaṉ paḻaṇi murukar potiya-māmalai Akattiya
                    <lb n="1v26=60" break="no"/> r rāmapattara-cuvāmi cīr-pātat=tiṉ āṇai tappātu yeluṉa
                    <lb n="1v27=61" break="no"/>vāru cuvāmiyavarkaḷ kompāṭum Oppam iṭṭu-t tām
                    <lb n="1v28=62" break="no"/>piṟa-cātaṉam Eḻuta-k kaṭṭaḷai y-iṭṭu maturai ṉāṭṭuk=ka
                    <lb n="1v29=63" break="no"/>ṇakku kōṉēriyappa-piḷ=ḷai kampapaka maṭalil va
                    <lb n="1v30=64" break="no"/>raintu kaṇṭa vācakattai-t tāmpira-p-paṭṭaya
                    <lb n="1v31=65" break="no"/>ttil veṭṭi varaintu Eḻutiṉēṉ maturai 
                    <lb n="1v32=66"/>c-cōmacunta<choice><orig>r=ā</orig><reg>ra</reg></choice>m ācāri <g ref="sym:tam-pillaiyarCuli" type="punctuation">.</g>
                </p>
                
                <ab xml:lang="tel-Latn" rendition="class:telugu maturity:undetermined" rend="large">
                    <seg rend="check"><lb n="1v33=67"/>cārraliṁgga tirumalanā
                        <lb n="1v34=68"/>larunayasanāru
                        <lb n="1v35=69"/>śrī manā * sahāmala *</seg>
                </ab>
                
                <lg n="1" met="anuṣṭubh" xml:lang="san-Latn" rendition="class:grantha maturity:83215">
                    <l n="a"><lb n="1v36=70"/> sva-dattā<supplied reason="omitted">d</supplied> dvi-guṇaṁ puṇyaṁ</l> 
                    <l n="b">para-datt<lb n="1v37=71"/>ānupālanaṁ</l> 
                    <l n="c">para-dattāpahāreṇa</l> 
                    <l n="d"><lb n="1v38=72"/>sva-dattaṁ niṣphalaṁ bhaveT</l> 
                </lg>
                
            </div>
            
