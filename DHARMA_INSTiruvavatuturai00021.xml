        <body>
            
            <div type="edition" xml:lang="tam-Latn" n="1" rendition="class:tamil maturity:vernacular">
                
                <p>
                    <pb n="1r"/>
                    <lb n="1r1=1"/> <g type="pc"/> <hi rend="grantha">svasti śrī ma</hi>kāmaṇṭalēcuparaṉ Ariyarāya taḷavipāṭaṉ pā<choice><orig>t</orig><reg>c</reg></choice>ai<seg type="aksara">k=ku</seg> <seg type="aksara">t=t</seg>appuvaRĀ 
                    <lb n="1r2=2"/>yira kaṇṭaṉ mūvaRĀya kaṇṭaṉ kaṇṭa nāṭu koṇṭu koṇṭa ṉāṭu kuṭātā
                    <lb n="1r3=3" break="no"/>ṉ pāṇṭimaṇṭala <hi rend="grantha">stā</hi>paṉācāriyaṉ cōḻamaṇṭala piṟati<hi rend="grantha">ṣṭācāriyan</hi>
                    <lb n="1r4=4"/>toṇṭamaṇṭala-c caṇṭappiracaṇṭaṉ Īḻamum koṅkum yā<choice><orig>ṇ</orig><reg>ḻ</reg></choice>ppā 
                    <lb n="1r5=5" break="no"/>ṇapaṭṭaṇamum kecavēṭṭai kaṇṭaruḷiya rācātirācaṉ rācaparamē 
                    <lb n="1r6=6" break="no"/>curaṉ rāca-mār<seg type="aksara">t=t</seg>āṇṭaṉ rāca-kempīraṉ rāca-kulatila<choice><orig>ta</orig><reg>ka</reg></choice>ṉ rāca-camē 
                    <lb n="1r7=7" break="no"/>ḷaṉ maṉṉaril maṉṉaṉ maruvalar kēcari tuṭṭaril <seg type="aksara">ttu</seg>ṭṭaṉ
                    <lb n="1r8=8"/>ciṭṭa paripālaṉ Oṭṭiyar mōkan tavuḷ<seg type="aksara">t=t</seg>āṉ tulu<seg type="aksara">k=ka</seg>r taḷavipā 
                    <lb n="1r9=9"/>ṭaṉ kaṭṭāri-c cāḷuvaṉ malaikkalaṅkiṉu maṉaṅkalaṅkātāṉ
                    <lb n="1r10=10"/>vaṅki nārāyaṇaṉ va<choice><orig>ṉu</orig><reg>ṇi</reg></choice>taiyarkaḷ maṭaleḻutu varucumukaṉ
                    <lb n="1r11=11"/>va<hi rend="grantha">śrā</hi>yutaṉ puṉitaṉ tēvar kalāntakaṉ <seg type="aksara">tta</seg>tu-pari nakulaṉ taḷaṅkaṇ
                    <lb n="1r12=12" break="no"/>ṭu <seg type="aksara">tta</seg>taḷippār muṇṭaṉ pañcavaṟṉaṉ RĀyaṉ paṉu<seg type="aksara">kku</seg>vĀR kaṇṭṭaṉ
                    <lb n="1r13=13"/>parataḷa vipāṭaṉ parimaḷa cukantaṉ paṭṭamāṉaṅ kā<seg type="aksara">t=t</seg>āṉ toṭṭavarān tava
                    <lb n="1r14=14" break="no"/>ṉātāṉ corimu<seg type="aksara">t=tu</seg> vaṉṉiyaṉ coṉṉamo<choice><orig>ḷ</orig><reg>ḻ</reg></choice>i tavaṟātāṉ Aṉṉa ca
                    <lb n="1r15=15" break="no"/>ttira cō<hi rend="grantha">maN A</hi>ntampara kaṇṭaṉ Aracarāvaṇa RĀmaṉ Aṭaik
                    <lb n="1r16=16" break="no"/>kalaṅ kā<seg type="aksara">tta</seg>vaṉ Aracu nilaiyiṭṭu AracaRĀṭṭan taviḷ<seg type="aksara">tt</seg>āṉ accan
                    <lb n="1r17=17"/>taviḷttāṉ pararācu maṉōkaraṉ pañcakāla payaṅkaraṉ pari<seg type="aksara">kku</seg> nakulaṉ
                    <lb n="1r18=18"/>vi<add place="below">l</add>lu<seg type="aksara">kku</seg> vicaiyaṉ collu<seg type="aksara">kku</seg> Ariccantiraṉ Āḷu<seg type="aksara">kku</seg> maṉmataṉ vāḷu<seg type="aksara">kku</seg>
                    <lb n="1r19=19"/>Apimaṉ virutu maṉṉiya kuṭĀRAṉ vīrappiratāpaṉ vīraveṇ<surplus>m</surplus>pāmālai
                    <lb n="1r20=20" break="no"/>yāṉ vīravempariyāṉ ve<seg type="aksara">t=ti</seg> maṇavāḷaṉ vēṟṟaraca tampiRĀṉ
                    <lb n="1r21=21"/>caturu<seg type="aksara">k=ka</seg>ḷ kaṇṭaṉ camaiya nĀR̄Āyaṇaṉ cāṭi<seg type="aksara">kk</seg>āṟar kaṇṭaṉ cāmu
                    <lb n="1r22=22" break="no"/><seg type="aksara">t=tu</seg>RŌkiyaḷ muṇṭaṉ caṅkīta cāyi<seg type="aksara">t=ti</seg>ya vi<seg type="aksara">t=ti</seg>yā viṉōtaṉ Aṭṭa
                    <lb n="1r23=23"/>leṭcumi piṟacaṉṉaṉ Iravikula cēkaraṉ tāli<seg type="aksara">k=ku</seg> vēli taḷañciṅ
                    <lb n="1r24=24" break="no"/>kam Iḷañciṅkam Ā<seg type="aksara">t=tu</seg>p pācci kaṭalil pācci toṇṭiya
                    <lb n="1r25=25" break="no"/>ṉtuṟai kāvalaṉ, tēvai naka<surplus>ra</surplus>rātipaṉ ceṅkāvi<seg type="aksara">k=ku</seg>ṭaiyāṉ cē
                    <lb n="1r26=26" break="no"/>tu<seg type="aksara">k=ka</seg>raip puli civapūca turantaraṉ taṉukkōṭi<seg type="aksara">k=k</seg>āvalaṉ RĀmaṉāta
                    <lb n="1r27=27"/>cuvāmi kāriyā turantiraṉ <unclear>vē</unclear>tiyar kāvalaṉ Intu vataṉa Ira 
                    
                    
                    <pb n="1v"/>
                    <lb n="1v1=28" break="no"/>ṇiya keṟpa Iravikula cēkara cōmātipati rekuṉātac cētupati kā
                    <lb n="1v2=29" break="no"/><seg type="aksara">t=ta</seg> tēvaravarkaḷ piṟiti<seg type="aksara">k=ka</seg> ṉaiyāka RĀcciya paripālaṉam paṇṇi Aru
                    <lb n="1v3=30" break="no"/>ḷā niṉṟa 
                </p>
                <p>
                    cāliyvākaṉac cakāṟttam <num value="1613"> <g type="numeral">1000</g> 6 <add place="below"><g type="numeral">100</g></add> <g type="numeral">10</g> 3</num> ṉ mēṟ cellā
                    <lb n="1v4=31"/>niṉṟa piṟacōṟpatti <g type="varuṣam"/> taiy <g type="tēti"/> <num value="15"> <g type="numeral">10</g> 5</num> <g type="tēti"/> 
                </p>
                <p>
                    murukappaṉ maṭa-taṟma
                    <lb n="1v5=32" break="no"/><seg type="aksara">t=tu</seg><seg type="aksara">k=ku</seg>m A<seg type="aksara">k=ki</seg>rakĀRA<seg type="aksara">t=tu</seg>kkum kaṭṭaḷaiyiṭṭa kiṟāmamāvatu 
                </p>
                <p>
                    tirup
                    <lb n="1v6=33" break="no"/>poṟkōṭṭai pakaiyaṉi piRĀntaṉi Inta <seg type="aksara">k=ki</seg>rāmaṅkaḷil
                    <lb n="34"/>taṟma<seg type="aksara">k=ki</seg>ṟāmam tiruppoṟkōṭṭai<seg type="aksara">k=ku</seg> Ll<choice><orig>k</orig><reg>l</reg></choice>ai yāvatu kīḷpāṟ
                    <lb n="35" break="no"/>kellai valaiyaṉ cōḷiyaṉ kaṇmāy<seg type="aksara">k=ku</seg>m Ēṟaṇikkōṭ
                    <lb n="36" break="no"/>ṭaik kaṇmāy<seg type="aksara">k=kuM</seg> mēṟku teṉpāṟkellai yāvatu ciṟu kaikka
                    <lb n="37" break="no"/>ṇmāy vaṭakkīṭkkompu vaṭakku mēṟpāṟkellai yāvatu
                    <lb n="38"/>Āmpaṭṭaṉ kōṭṭai ceṭṭi Ēntal puḷiyāṇṭāṉ karicalu<seg type="aksara">k=ku</seg> kiḷa
                    <lb n="39" break="no"/><seg type="aksara">kku</seg> vaṭapāṟkellai yāvatu tu<seg rend="check"><seg type="aksara">t=tū/t=tā</seg></seg><seg type="aksara">k=ku</seg>ṭi ¯
                    Āttu<seg rend="check">k=ku</seg> teṟku maramatā
                    <lb n="40" break="no"/>ya kiṟāmam pakaiyeṉi pirāntiṉikku Al<choice><orig>k</orig><reg>l</reg></choice>ai yāvatu kīḷ
                    <lb n="41"/>pārkellai pāppāṉ kōṭṭai Amaṉippuḷi yāla<seg type="aksara">k=ka</seg>ṇmāyaḷu
                    <lb n="42" break="no"/><seg type="aksara">k=ku</seg> mēṟku teṉpāṟkellai tiṭakkōṭṭai vaṭavayalu<seg type="aksara">k=ku</seg> va
                    <lb n="43" break="no"/>ṭa<seg type="aksara">k=ku</seg> mēlpāṟkellai cāṇāṉēntal koḷḷuṭaiyār taṉmattu
                    <lb n="44"/>neymēṉi<seg type="aksara">k=kuM</seg> kiḷa<seg type="aksara">k=ku</seg> vaṭapāṟkellai Araiyēṉit te<add place="below">ṉ</add>vayal nalla
                    <lb n="45" break="no"/>vatēvaṉ Ūṟaṇi<seg type="aksara">k=ku</seg>m teṟku 
                </p>
                <p>
                    Iṉṉāṉkel<choice><orig>k</orig><reg>l</reg></choice>ai<seg type="aksara">k=ku</seg>ḷ paṭṭa māvaṭai
                    <lb n="46"/>maravaṭai <seg rend="check"><seg type="aksara">tiṭ</seg>ṭut <seg type="aksara">tiṭa</seg>l</seg> pāmpāṭu paṉai vaṭali Āvirai koḻuñci kīḷnō
                    <lb n="47" break="no"/><unclear><seg type="aksara">kki</seg></unclear>ya <add place="below">mēl nōkkiyamām <g type="cross"/></add> kiṇaṟu niti niṭcēpam cakalamum taṟma<seg type="aksara">t=tu</seg><seg type="aksara">k=ku</seg> A<seg type="aksara">kki</seg>rakĀRA<seg type="aksara">t=tu</seg><seg type="aksara">k=kuM</seg> caṟu
                    <lb n="48" break="no"/>vamāṉiyamāka <seg type="aksara">k=k</seg>aṭṭaḷaiyiṭṭapaṭiyiṉālē 
                </p>
                
                <p>
                    Ituvē tāmpura-tāṉa-p-paṭṭayam-<add place="below">ā</add>
                    <lb n="1v22=49" break="no"/>ka cantiRĀtit=tavarai<!--EF: how to indicate that the offset Nāgari phrase is here? In apparatus?--> cantirap<!--EF:check-->-piṟavēca-maṭa-taṟmamum 
                    <lb n="1v23=50"/>Ak=kiṟakĀRamum Ut=tiRŌt=tiram-āka naṭappiccu-k koḷḷavum
                </p>
                <p>
                    Inta taṟmat
                    <lb n="1v24=51" break="no"/>tai yātām oruttaṉ paripālaṉam paṇṇiṉavaṉ kōṭi-liṅka-p-pi<unclear>ṟa</unclear> 
                    <lb n="1v25=52" break="no"/>tiṭṭai-kōṭi-viṟuma-p-piṟatiṭṭaiyu=M Acuvamētai-yākam paṇṇiṉa <unclear>pa</unclear> 
                    <lb n="1v26=53" break="no"/>lattai Aṭaivar ākavum
                </p>
                <p>
                    Inta taṟmattuk=ku Akitam paṇṇiṉavaṉ kuruv<unclear>ai</unclear>
                    <lb n="1v27=54"/>keṅkaikaraiyil kāRĀpacuvai ko<choice><orig>ṇṇ</orig><reg>ṉṟ</reg></choice>a pāvat=tilē pōvaR Āka<unclear>vum</unclear>
                </p>
                
                <ab xml:lang="san-Latn" rendition="class:nāgarī maturity:vernacular">
                    <lb n="049"/>raghunātha-kā<seg rend="check">ge<unclear reason="eccentric_ductus">ṇye</unclear></seg>
                </ab>
                
            </div>
            
            
