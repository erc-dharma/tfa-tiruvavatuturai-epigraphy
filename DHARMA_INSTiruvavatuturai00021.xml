        <body>
            
            <div type="edition" xml:lang="tam-Latn" n="1" rendition="class:tamil maturity:vernacular">
                
                <p>
                    <pb n="1r"/>
                    <lb n="1r1=1"/> <g type="pc"/> <hi rend="grantha">svasti śrī ma</hi>kāmaṇṭalēcuparaṉ Ariyarāya taḷavipāṭaṉ pā<choice><orig>t</orig><reg>c</reg></choice>ai<seg type="aksara">k=ku</seg> <seg type="aksara">t=t</seg>appuvaRĀ 
                    <lb n="1r2=2"/>yira kaṇṭaṉ mūvaRĀya kaṇṭaṉ kaṇṭa nāṭu koṇṭu koṇṭa ṉāṭu kuṭātā
                    <lb n="1r3=3" break="no"/>ṉ pāṇṭimaṇṭala <hi rend="grantha">stā</hi>paṉācāriyaṉ cōḻamaṇṭala piṟati<hi rend="grantha">ṣṭācāriyan</hi>
                    <lb n="1r4=4"/>toṇṭamaṇṭala-c caṇṭappiracaṇṭaṉ Īḻamum koṅkum yā<choice><orig>ṇ</orig><reg>ḻ</reg></choice>ppā 
                    <lb n="1r5=5" break="no"/>ṇapaṭṭaṇamum kecavēṭṭai kaṇṭaruḷiya rācātirācaṉ rācaparamē 
                    <lb n="1r6=6" break="no"/>curaṉ rāca-mār<seg type="aksara">t=t</seg>āṇṭaṉ rāca-kempīraṉ rāca-kulatila<choice><orig>ta</orig><reg>ka</reg></choice>ṉ rāca-camē 
                    <lb n="1r7=7" break="no"/>ḷaṉ maṉṉaril maṉṉaṉ maruvalar kēcari tuṭṭaril <seg type="aksara">ttu</seg>ṭṭaṉ
                    <lb n="8"/>ciṭṭa paripālaṉ Oṭṭiyar mōkan tavuḷ<seg type="aksara">t=t</seg>āṉ tulu<seg type="aksara">k=ka</seg>r taḷavipā 
                    <lb n="9"/>ṭaṉ kaṭṭāri-c cāḷuvaṉ malaikkalaṅkiṉu maṉaṅkalaṅkātāṉ
                    <lb n="10"/>vaṅki nārāyaṇaṉ va<choice><orig>ṉu</orig><reg>ṇi</reg></choice>taiyarkaḷ maṭaleḻutu varucumukaṉ
                    <lb n="11"/>va<hi rend="grantha">śrā</hi>yutaṉ puṉitaṉ tēvar kalāntakaṉ <seg type="aksara">tta</seg>tu-pari nakulaṉ taḷaṅkaṇ
                    <lb n="12" break="no"/>ṭu <seg type="aksara">tta</seg>taḷippār muṇṭaṉ pañcavaṟṉaṉ RĀyaṉ paṉu<seg type="aksara">kku</seg>vĀR kaṇṭṭaṉ
                    <lb n="13"/>parataḷa vipāṭaṉ parimaḷa cukantaṉ paṭṭamāṉaṅ kā<seg type="aksara">t=t</seg>āṉ toṭṭavarān tava
                    <lb n="14" break="no"/>ṉātāṉ corimu<seg type="aksara">t=tu</seg> vaṉṉiyaṉ coṉṉamo<choice><orig>ḷ</orig><reg>ḻ</reg></choice>i tavaṟātāṉ Aṉṉa ca
                    <lb n="15" break="no"/>ttira cō<hi rend="grantha">maN A</hi>ntampara kaṇṭaṉ Aracarāvaṇa RĀmaṉ Aṭaik
                    <lb n="16" break="no"/>kalaṅ kā<seg type="aksara">tta</seg>vaṉ Aracu nilaiyiṭṭu AracaRĀṭṭan taviḷ<seg type="aksara">tt</seg>āṉ accan
                    <lb n="17"/>taviḷttāṉ pararācu maṉōkaraṉ pañcakāla payaṅkaraṉ pari<seg type="aksara">kku</seg> nakulaṉ
                    <lb n="18"/>vi<add place="below">l</add>lu<seg type="aksara">kku</seg> vicaiyaṉ collu<seg type="aksara">kku</seg> Ariccantiraṉ Āḷu<seg type="aksara">kku</seg> maṉmataṉ vāḷu<seg type="aksara">kku</seg>
                    <lb n="19"/>Apimaṉ virutu maṉṉiya kuṭĀRAṉ vīrappiratāpaṉ vīraveṇ<surplus>m</surplus>pāmālai
                    <lb n="20" break="no"/>yāṉ vīravempariyāṉ ve<seg type="aksara">t=ti</seg> maṇavāḷaṉ vēṟṟaraca tampiRĀṉ
                    <lb n="21"/>caturu<seg type="aksara">k=ka</seg>ḷ kaṇṭaṉ camaiya nĀR̄Āyaṇaṉ cāṭi<seg type="aksara">kk</seg>āṟar kaṇṭaṉ cāmu
                    <lb n="22" break="no"/><seg type="aksara">t=tu</seg>RŌkiyaḷ muṇṭaṉ caṅkīta cāyi<seg type="aksara">t=ti</seg>ya vi<seg type="aksara">t=ti</seg>yā viṉōtaṉ Aṭṭa
                    <lb n="23"/>leṭcumi piṟacaṉṉaṉ Iravikula cēkaraṉ tāli<seg type="aksara">k=ku</seg> vēli taḷañciṅ
                    <lb n="24" break="no"/>kam Iḷañciṅkam Ā<seg type="aksara">t=tu</seg>p pācci kaṭalil pācci toṇṭiya
                    <lb n="25" break="no"/>ṉtuṟai kāvalaṉ, tēvai naka<surplus>ra</surplus>rātipaṉ ceṅkāvi<seg type="aksara">k=ku</seg>ṭaiyāṉ cē
                    <lb n="26" break="no"/>tu<seg type="aksara">k=ka</seg>raip puli civapūca turantaraṉ taṉukkōṭi<seg type="aksara">k=k</seg>āvalaṉ RĀmaṉāta
                    <lb n="27"/>cuvāmi kāriyā turantiraṉ <unclear>vē</unclear>tiyar kāvalaṉ Intu vataṉa Ira 
                    
                    
                    <pb n="1v"/>
                    <lb n="1v1=28"/>ṇiya keṟpa iravikula cēkara cōmātipati rekunātac cētupati, kā
                    <lb n="29"/>tta tēvaravarkaḷ' piṟatikkaṉaiyāka rācciya paripālaṉam paṇṇi aru
                    <lb n="30"/>ḷāniṉṟa cāliyavākaṉac cakāṟttam 1613-ṉ mēṟ cellā
                    <lb n="31"/>niṉṟa piṟacōṟpatti varuṭam tai mī 15 tī murukappaṉ maṭataṟma
                    <lb n="32"/>ttukkum akkirakārattukkum kaṭṭaḷaiyiṭṭa kiṟāmamāvatu tirup
                    <lb n="33"/>poṟkōṭṭai, pakaiyaṉi pirāntaṉi intak kirāmaṅkaḷil
                    <lb n="34"/>taṟmakkiṟāmam tiruppoṟkōṭṭaikku elkaiyāvatu - kīḷpāṟ
                    <lb n="35"/>kellai valaiyaṉ cōḷiyaṉ kaṇmāykkum ēṟaṇikkōṭ
                    <lb n="36"/>ṭaik kaṇmāykkum mēṟku teṉpāṟ kellaiyāvatu ciṟukaikka
                    <lb n="37"/>ṇmāy vaṭakkīḻkkompu vaṭakku mēṟpāṟ kellaiyāvatu
                    <lb n="38"/>āmpaṭṭaṉ kōṭṭai, ceṭṭi ēntal, puḷiyāṇṭāṉ karicalukkuk kiḷa
                    <lb n="39"/>kku. vaṭapāṟ kellaiyāvatu tukkākkuṭi āttukku teṟku piramatā
                    <lb n="40"/>yak kiṟāmam. pakaiyeṉi pirāntiṉikku elkaiyāvatu. kīḷ
                    <lb n="41"/>pākkellai pāppāṉ kōṭṭai amaṉippuḷi yālakkaṇmāyaḷu
                    <lb n="42"/>kku mēṟku. teṉpāṟkellai tiṭakkōṭṭai vaṭavayalukku va
                    <lb n="43"/>ṭakku. mēṟpāṟkellai cāṇāṉēntal" koḷḷuṭaiyār taṉmattu
                    <lb n="44"/>neymēṉikkum kiḷakku. vaṭapāṟkellai araiyēṉit teṉvaṭalnavatē
                    <lb n="45"/>vatēvaṉ ūṟaṇikkum teṟku. iṉṉāṉkellaikkuḷpaṭṭa māvaṭai,
                    <lb n="46"/>maravaṭai, tiṭṭut tiṭal, pāmpāṭu, paṉai, vaṭali, āvirai koḻuñci, kīḷnōk
                    <lb n="47"/>kiya kiṇaṟu, niti, niṭcēpam cakalamum taṟmattukku akkirakārattukku caṟu
                    <lb n="48"/>vamāṉiyamāka kaṭṭaḷaiyiṭṭapaṭiyiṉālē 
                </p>
                
                <p>
                    Ituvē tāmpura-tāṉa-p-paṭṭayam-<add place="below">ā</add>
                    <lb n="1v22=49" break="no"/>ka cantiRĀtit=tavarai<!--EF: how to indicate that the offset Nāgari phrase is here? In apparatus?--> cantirap<!--EF:check-->-piṟavēca-maṭa-taṟmamum 
                    <lb n="1v23=50"/>Ak=kiṟakĀRamum Ut=tiRŌt=tiram-āka naṭappiccu-k koḷḷavum
                </p>
                <p>
                    Inta taṟmat
                    <lb n="1v24=51" break="no"/>tai yātām oruttaṉ paripālaṉam paṇṇiṉavaṉ kōṭi-liṅka-p-pi<unclear>ṟa</unclear> 
                    <lb n="1v25=52" break="no"/>tiṭṭai-kōṭi-viṟuma-p-piṟatiṭṭaiyu=M Acuvamētai-yākam paṇṇiṉa <unclear>pa</unclear> 
                    <lb n="1v26=53" break="no"/>lattai Aṭaivar ākavum
                </p>
                <p>
                    Inta taṟmattuk=ku Akitam paṇṇiṉavaṉ kuruv<unclear>ai</unclear>
                    <lb n="1v27=54"/>keṅkaikaraiyil kāRĀpacuvai ko<choice><orig>ṇṇ</orig><reg>ṉṟ</reg></choice>a pāvat=tilē pōvaR Āka<unclear>vum</unclear>
                </p>
                
                <ab xml:lang="san-Latn" rendition="class:nāgarī maturity:vernacular">
                    <lb n="049"/>raghunātha-kāge<unclear reason="eccentric_ductus">ṇye</unclear><!--EF:check-->
                </ab>
                
            </div>
            
            
