        <body>
            
            <div type="edition" xml:lang="tam-Latn" n="1" rendition="class:tamil maturity:83215">		
                
                
                <pb n="1r"/>
                <p>
                    <lb n="1r1=1"/><hi rend="grantha">svasti śrī śakābdam</hi> <num value="1582"> <g type="numeral">1000</g> 5 <g type="numeral">100</g> 8 <g type="numeral">10</g> 2</num> mēl cellā niṉra <hi rend="grantha">sarvari</hi> nā<hi rend="grantha">ma saṁvat·sara</hi>ttu Ut=ta<hi rend="grantha">rā</hi>
                    <lb n="1r2=2" break="no"/>yaṇattu <hi rend="grantha">māgha māca</hi>ttu <hi rend="grantha">Apara pakṣa</hi>ttu<hi rend="grantha">rddasī</hi>yum <hi rend="grantha">Ātitya</hi> vā<hi rend="grantha">ra</hi>mum Aviṭṭa na<hi rend="grantha">kṣa</hi>ttamum civa nā
                    <lb n="1r3=3" break="no"/>ma yō<hi rend="grantha">ga</hi>mum peṟṟa <hi rend="grantha">puṇya kāla</hi>ttu
                </p>  
                <p>    
                    tirupperuntuṟaiyil Āvuṭaiya-p-parama-cuvāmiyārkku U<hi rend="grantha">ṣ</hi>ā-kā
                    <lb n="1r4=5" break="no"/>la-pūcai-k-kaṭṭaḷai naṭattum paratēci-muttirai-y-āṉa Ampalattāṭum paṇṭāram Avarkaḷukku 
                </p>      
                <p>
                    <lb n="1r5=5"/>tēvai nakarātipaṉ cetumūla<hi rend="grantha">rakṣā</hi>turantaraṉ Iramanāta cuvāmi paṟuvata-vattaṉi-y-ammai kāriya-tu
                    <lb n="1r6=6" break="no"/>rantaraṉ cuppiramaṇiya pātāravinta cēvitaṉ para-rā<supplied reason="omitted">ca</supplied>-ciṅkam para-rāca-cūriyaṉ para-rāca-cēkaraṉ Iravi
                    <lb n="1r7=7" break="no"/>kula-cēkaraṉ cori-muttu-vaṉṉiyaṉ tuṭṭa-rāyira kaṇṭaṉ cāṭikkāṟar kaṇṭaṉ cāmi-t-tur=ō
                    <lb n="1r8=8" break="no"/>ki<add place="below">ya</add>ḷ miṇṭaṉ Anta<add place="below">m</add>para-kaṇṭaṉ Aṭiyār <add place="below">v</add>ēḷaikkāṟaṉ Araica-rāvaṇa-rāmaṉ pañcattu māri paṉu
                    <lb n="1r9=9" break="no"/>kkuvār kaṇṭaṉ paṭṭa māṉaṅ kāttāṉ paṭṭam param piṭittāṉ tālikku vēli Iravi
                    <lb n="1r10=10" break="no"/>ya-p puli Iḷañ ciṅkam <add place="below">taḷañ ciṅkam</add> vīra-veṇ<surplus>m</surplus><add place="below">pā</add>mālai vaikai vaḷa-nāṭaṉ para-tāḷa-vipāṭaṉ pañca-vaṉṉa-r
                    <lb n="1r11=11" break="no"/>āya-rāvuttaṉ puvaṉēkavīraṉ vētiyar kāvalaṉ koṭṭam aṭakki vayyāḷi nārāyaṇa
                    <lb n="1r12=12" break="no"/>ṉ Ivvuḷi pāvaṭi mititt' ēṟuvār kaṇṭaṉ pakai-maṉṉar ciṅkam āttil pācci kaṭaliṟ pācci
                    <lb n="1r13=13"/>catturukkaḷ miṇṭaṉ mēvalar kōḷari vīra-kempīraṉ kīrtti-p piṟatāpaṉ, pakai-nāṭa
                    <pb n="1v"/>
                    <lb n="1v1=14"/>ka cūttira-p piṟatāpaṉ patti mutti-p piṟiyaṉ vīra-la<hi rend="grantha">kṣmi</hi> vic<add place="below">ai</add>ya laṭcumi, pāykkiya laṭcumi kāntaṉ, ca
                    <lb n="1v2=15"/>rṟpaṉṉa pāṣā vicakṣcaṇaṉ, cakala kuṇa campaṇṇaṉ, caṅkīta cākitya vityā vinōtaṉ, tirumalai narē 
                    <lb n="1v3=16"/>ntiraṉ, mecciya cāmit turōkiyaḷ miṇṭaṉ, vīrai vaḷanāṭaṉ, toṇṭiyan tuṟaivaṉ, aṭaikkala
                    <lb n="1v4=17"/>ṅ kāttāṉ, vaṉṉiyarāṭṭan taviḻttāṉ, mūvarāyira kaṇṭaṉ, cāmitturōka veṇṭaiya kāva
                    <lb n="1v5=18"/>laṉ, vīrataṇṭai cēmattalai viḷaṅkiyatāḷiṉāṉ, turairāyaṉ, ceyatuṅkarāyaṉ, vamcātipaṉā
                    <lb n="1v6=19"/>ṉ, tukavūrk kūṟṟattuk kātturāṉa kulōttuṅka cōḻa nallūr kīḻpāl viraiyāta kaṇṭaṉil iruk-
                    <lb n="1v7=20"/>kum taḷavāy cētupati putraṉ srī tirumalaiya cētupati rakunātat tēvar kattākkaḷ                     

                </p>
                
                <p>
                    tirumalaināyakka 
                    <lb n="1v8=21"/>raiyaṉ avarkaḷukkum taḷavāy cetupati kāttattēvar avarkaḷukkum Eṅkaḷ mātā pitāpitāviṉuṭaiya paṟṟa
                    <lb n="1v9=22"/>kattukkum puṇṇiyamākat taṉmacātaṉap paṭṭayaṅ kuṭuttapaṭi yintap paratēcik kaṭṭaḷaiyi
                    <lb n="1v10=23"/>l cēntu naṭakkiṟa kiṟāmaṅkaḷ veḷlāmpaṟṟuc cīmai añciraṇṭuc cīmai, ārantāṅkic cīmai, paṭṭukkōṭ
                    <lb n="1v11=24"/>ṭaic cīmai, putukkōṭṭaic cīmai, tiruppattūr cūraikkuṭic cīmai, tērpōkināṭu, muttunāṭu intac cīmaika
                    <lb n="1v12=25"/> ḷilē naṭakkiṟa kiṟāmaṅkaḷ, ēntal, uḷkkiṭai mutalākiyatukkellām paḷvari mutalākiya cakala palavariyaḷum kaṭṭaḷaiyiḷē cērnta maṉuṣar uḷpaṭa kōcālai 
                    <lb n="1v13=26"/>vari naṉmāṭuvari, makā navami kiṭāy, ōṭṭukiṟatu uramiṟiyil maṟṟu muṇṭākiya pala cillaṟai variyaḷum vēṇṭāmeṉṟu
                    <lb n="1v14=27"/>nām apimāṉattuc caṟuva māṉiyamākak kaṭṭaḷaiyiṭṭa paṭiyiṉālē </p>
                <p>
                    nammai Aṭainta maṉu<hi rend="grantha">ṣa</hi>r ellām Inta-t taṉma-cā
                    <lb n="1v15=28" break="no"/>taṉap paṭṭaiya-p-paṭikku Oru cillaṟaikaḷum vārāmal Inta-p puṇṇiyattai paripālaṉam <unclear>pa</unclear>
                    
                    <pb n="2r"/>
                    
                    <lb n="2r1=29"/>ṇṇi-p pūṟuvāpūṟuvam naṭanta paṭiyē Uttarōttaramāka naṭappikka-k kaṭavōr ākavum 
                </p>
                <p>
                    Inta-t ta
                    <lb n="2r2=30"/>ṉmattai yātāmorutar paripālaṉam paṇṇiṉa pērkaḷ keṅkai-k karaiyilum cētuk karaiyilum Ā
                    <lb n="2r3=31" break="no"/>yiraṅ kapilai-p pacuvum Āyiram pirāmaṇar k=kuṭumpa-p piṟatiṭṭaiyum Aṉēka kōṭi pūtāṉa kaṉṉi
                    <lb n="2r4=32"/>yātāṉamum paṇṇiṉa puṇṇiyattai Aṭaiya-k kaṭavārākavum Anēka tōṭi civaliṅka piṟatiṭṭai
                    <lb n="2r5=33"/>paṇṇiṉa puṇṇiyattai<add place="below">yum</add> Aṭaiya-k kaṭavarākavum Intat taṉmattukku yātoruttar Akitam paṇ
                    <lb n="2r6=34" break="no"/>ṇiṉa pērkaḷ keṅkai-k karayilum cētukkaraiyilum kārām pacuvaiyum kuruvaiyum māta-
                    <lb n="2r7=35"/>pitāvaiyum koṉṟa tō<hi rend="grantha">ṣa</hi>ttilē pōka-k kaṭavār ākavum 
                </p>
                <p>
                    Ippaṭi cammatittu <hi rend="grantha">srī</hi> tirumalaiya cētupati <hi rend="grantha">raghu</hi>nā
                    <lb n="2r8=36" break="no"/><hi rend="grantha">tha</hi> tēvar Āvuṭaiya paramacuvāmiyārk=ku U<hi rend="grantha">ṣā</hi>kāla pūcaik kaṭṭaḷai naṭattum Ampalattāṭum paṇṭāram Ava
                    <lb n="2r9=37" break="no"/>rkaḷukku <hi rend="grantha">dharmma śāsana</hi>-p paṭṭaiyam kuṭuttōm ippaṭikku <g ref="sym:tam-pillaiyarCuli" type="ideogram">@</g>
                </p>
                
                
                <ab xml:lang="tel-Latn" rendition="class:telugu maturity:vernacular">
                    <lb n="2r10=38"/>śrī subhramaṇya tirumalaiya sētupati raghunātha 
                </ab>
                
                <p>
                    <lb n="2r11=39"/><hi rend="grantha">svastir astu </hi><g ref="sym:tam-pillaiyarCuli" type="ideogram">@</g>
                </p>
                                
                <lg n="1" met="anuṣṭubh" xml:lang="san-Latn" rendition="class:grantha maturity:83215">
                    <l n="a">dānapālanayōr mmaddhyē</l> 
                    <l n="b">dā<choice><orig>t</orig><reg>n</reg></choice>āt cchreyo ’nupālanam· <g ref="sym:bar" type="punctuation">.</g></l> 
                    <l n="c">dānāt· svargam avā<lb n="2r12=40"/>pnōti</l> 
                    <l n="d">pālanād acyutam· padam· <g ref="sym:doubleBar" type="punctuation">.</g> <g ref="sym:tam-pillaiyarCuli" type="ideogram">@</g></l> 
                </lg>
                
                
                
