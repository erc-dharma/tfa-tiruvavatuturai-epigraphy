        <body>
            
            <div type="edition" xml:lang="tam-Latn" rendition="class:tamil maturity:83215">
                
                <ab>
                    <lb n="1"/><hi rend="grantha">svasti śrī</hi>
                </ab>
                
                <p>
                    tiru-naṟai
                    <lb n="2" break="no"/>yūr-nāṭṭu ciṟṟāṭi-y-u
                    <lb n="3" break="no"/>ṭaiyāṉ tāmaṉ A
                    <lb n="4" break="no"/>malaṉ <g ref="sym:flourish-taperOut" type="punctuation">.</g>
                </p>
                
                <ab>
                    na<hi rend="grantha">maś śi</hi>vāya
                </ab>
                
            </div>
            
            <!--<div type="apparatus">			
